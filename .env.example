# PostgreSQL
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_dev
POSTGRES_DB=taskflow

# Database connection (used by the API server)
# "db" matches the service name in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://taskflow:taskflow_dev@db:5432/taskflow

# Alembic needs a sync driver for migrations
DATABASE_URL_SYNC=postgresql://taskflow:taskflow_dev@db:5432/taskflow

# JWT — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRY_HOURS=24

# Bcrypt work factor (minimum 12 per spec)
BCRYPT_COST=12
